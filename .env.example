# 複製這個檔案成 .env 後填入真正的值（.env 已被 .gitignore 排除，不會進版控）
#   cp .env.example .env

# ── 核心（缺這些主要功能會壞）──
OPENAI_API_KEY=XXXXXXXXXXXX          # 聊天、TTS、STT、故事生成（OpenAI）
GEMINI_API_KEY=XXXXXXXXXXXX          # 繪本算圖 + AI 審核（review-drawing / review-design）（Google Gemini）
MIXPANEL_PROJECT_TOKEN=XXXXXXXXXXXX  # 前端事件分析（Mixpanel）
APP_ENV=development                  # development / production
APP_NAME=gpt-clone

# ── 選用（各自對應特定功能，用不到可留空）──
PIXELLAB_API_KEY=      # AI 助理頭像的像素圖生成（create-avatar）
FAL_API_KEY=           # fal.ai 影像/影片生成
POLLINATIONS_API_KEY=  # Pollinations 影像生成
SEEDANCE_API_KEY=      # Seedance 影片生成
ELEVENLABS_API_KEY=    # Lab Music / ElevenLabs Music API
ELEVENLABS_MUSIC_MODEL=music_v1
FACE_SERVER_URL=       # 臉部處理服務位址

# 註：Firebase 設定是「寫死」在 src/lib/firebase.ts（專案沒有 Firebase Auth，
#     改用 localStorage 當 session），所以這裡不需要 Firebase 相關變數。
